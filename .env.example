# スクリプト用パラメータの雛形。コピーして .env を作り、値を記入する。
#   cp .env.example .env
# .env は gitignore 済み（秘密情報を含むためコミットしない）。
# scripts/*.cjs が起動時に .env を読み込む（インラインの環境変数が優先）。

# --- ODPT（公共交通オープンデータ）API キー: scripts/fetch-odpt-trains.cjs 用 ---
# 本体 API（東京メトロ/都営/つくばEX/京成 等）。https://www.odpt.org/
ODPT_TOKEN=
# チャレンジ系 API（JR東日本の列車時刻表）。取得保留中は空のままでよい。
ODPT_CHALLENGE_TOKEN=

# --- ビルド入力データのパス: scripts/build-chiba-jr.cjs 用（省略時は ./.data/ 配下）---
# 値は node を実行する場所（リポジトリ直下）からの相対 or 絶対パス。
# N02_DIR=./.data/N02/UTF-8
# JAPAN_GEOJSON=./.data/japan.geojson
