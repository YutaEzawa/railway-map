    "dasharray": [2, 2],
    "width": [
      { "zoom": 8, "w": 1 },
      { "zoom": 12, "w": 1.8 },
      { "zoom": 16, "w": 3.2 }
    ]
  },
  "parallelOffset": [
    { "zoom": 8, "px": 1.5 },
    { "zoom": 12, "px": 3 },
    { "zoom": 16, "px": 6 }
  ]
}
