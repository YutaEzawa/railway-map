    { "zoom": 12, "tiers": [1.6, 3.2, 5] },
    { "zoom": 16, "tiers": [3, 6, 9] }
  ],
  "casing": [
    { "zoom": 8, "tiers": [1.8, 2.8, 4] },
    { "zoom": 12, "tiers": [3, 5, 7.2] },
    { "zoom": 16, "tiers": [5, 8.4, 11.5] }
